<% layout('layouts/boilerplate') %>
    <div class="container title">
        <h1 class="display-1"><i>AAA Network Solutions</i></h1>
    </div>

    <div class="container title">
        <h3>
            List of items: <%=name %>
        </h3>
    </div>

    <form action="/products" method="GET" id="searchFilterForm" class="container row my-4 mx-auto px-0 gap-2">
        <div class="col-md-5">
            <input type="text" name="search" id="tableSearchInput" class="form-control"
                placeholder="🔍 Search by product name or brand..." value="<%= searchQuery %>">
        </div>
        <div class="col-md-4">
            <select name="category" id="categoryFilterSelect" class="form-select">
                <option value="all">All Categories</option>
                <option value="cable">Cables</option>
                <option value="workstation">Workstations</option>
                <option value="access point">Access Points</option>
                <option value="server">Servers</option>
                <option value="router">Routers</option>
                <option value="switch">Switches</option>
                <option value="printer">Printers</option>
                <option value="accessory">Accessories</option>
            </select>
        </div>
        <div class="col-md-2 px-0">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
    </form>
    <% if (products.length> 0) { %>
        <div class="row mx-0">
            <table class="table table-primary table-hover">
                <thead>
                    <tr>
                        <th scope="col"></th>
                        <th scope="col">Category</th>
                        <th scope="col">Brand</th>
                        <th scope="col">Name</th>
                        <th scope="col">In Stock</th>
                        <th scope="col">Price per Unit</th>
                    </tr>
                </thead>
                <tbody>
                    <% for (let product of products) { %>
                        <tr class="table-info">
                            <th scope="row"></th>
                            <td>
                                <a href="/products?category=<%=product.category %>">
                                    <%=product.category %>
                                </a>


                            </td>
                            <td>
                                <%= product.brand%>
                            </td>
                            <td>
                                <a href="/products/<%=product._id %>">
                                    <%=product.name%>
                                </a>

                            </td>
                            <td>
                                <%= product.quantity%>
                            </td>
                            <td>
                                £<%= product.price%>
                            </td>
                        </tr>
                        <%} %>


                </tbody>
            </table>
        </div>
        <% } else { %>
            <div class="container px-0 my-5 text-center">
                <div class="alert alert-warning py-4 shadow-sm" role="alert">
                    <h4 class="alert-heading">⚠️ No Products Found</h4>
                    <p class="mb-0">Your query <strong>"<%= searchQuery %>"</strong> did not match any items in our
                        warehouse inventory.</p>
                    <hr>
                    <p class="small text-muted mb-0">Try checking your spelling or selecting a different component
                        category.</p>
                </div>
            </div>
            <% } %>
                <% if (totalPages> 1) { %>
                    <nav aria-label="Product inventory page navigation" class="my-4">
                        <ul class="pagination justify-content-center">

                            <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
                                <a class="page-link"
                                    href="/products?page=<%= currentPage - 1 %>&search=<%= searchQuery %>&category=<%= selectedCategory %>">
                                    Previous
                                </a>
                            </li>

                            <% for (let i=1; i <=totalPages; i++) { %>
                                <li class="page-item <%= currentPage === i ? 'active' : '' %>">
                                    <a class="page-link"
                                        href="/products?page=<%= i %>&search=<%= searchQuery %>&category=<%= selectedCategory %>">
                                        <%= i %>
                                    </a>
                                </li>
                                <% } %>

                                    <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
                                        <a class="page-link"
                                            href="/products?page=<%= currentPage + 1 %>&search=<%= searchQuery %>&category=<%= selectedCategory %>">
                                            Next
                                        </a>
                                    </li>

                        </ul>
                    </nav>
                    <% } %>

                        <% if (currentUser && currentUser.role==="admin" ) {%>
                            <button class="btn btn-warning" onclick="document.location='/products/new'">Add New
                                (admin)</button>
                            <%} %>
                                <% if (name!=='All Products' ) {%>
                                    <button class="btn btn-info" onclick="document.location='/products'">Show
                                        All</button>

                                    <% } %>