<% layout('layouts/boilerplate') %>
    <h1 class="display-5 text-center mb-4"><strong>forgot password?</strong></h1>
    <div class="container w-75">
        <div class="card shadow p-4">
            <form action="/users/iForgot" method="POST" novalidate class="validated-form">


                <div class="mb-4">
                    <label for="email">Email:</label>
                    <input type="email" name="email" id="email" placeholder="xyz@t.com" class="form-control" required>
                </div>


                <div class="d-flex gap-2">
                    <button class="btn btn-warning px-4">Submit</button>

                </div>
            </form>
        </div>
    </div>