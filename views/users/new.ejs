<% layout('layouts/boilerplate') %>
    <h1 class="display-5 text-center mb-4"><strong>Sign Up</strong></h1>
    <!-- Input form -->
    <div class="container w-75">
        <div class="card shadow p-4">
            <form action="/users/register" method="POST" novalidate class="validated-form">

                <div class="mb-3">
                    <label for="username" class="form-label">Username:</label>
                    <input type="text" name="username" id="username" placeholder="username" class="form-control"
                        required>
                    <div class="valid-feedback">This one looks good</div>
                </div>

                <div class="mb-4">
                    <label for="password" class="form-label">Password:</label>
                    <input type="password" name="password" id="password" placeholder="password" class="form-control"
                        required>
                    <div class="valid-feedback">This one looks good</div>
                </div>
                <div class="mb-4">
                    <label for="email">Email:</label>
                    <input type="email" name="email" id="email" placeholder="xyz@t.com" class="form-control" required>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-warning px-4">Register</button>
                    <button type="button" class="btn btn-info px-4"
                        onclick="document.location='/products'">Cancel</button>
                </div>
            </form>
        </div>
    </div>