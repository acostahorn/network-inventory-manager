<% layout('layouts/boilerplateDesign') %>
    <% if (currentUser && currentUser.role==='admin' && user.designStatus==='Pending Approval' ) { %>
        <div class="card border-primary mb-4 shadow-sm">
            <div class="card-header bg-primary text-white"><strong>Admin Review Mode</strong></div>
            <div class="card-body">
                <form action="/users/<%=user._id%>/approve-design" method="POST" class="row g-3 align-items-center">
                    <div class="col-md-4">
                        <label class="form-label">Estimated Labour Cost (£)</label>
                        <input type="number" step="0.01" min="0" name="labourCost" class="form-control"
                            placeholder="e.g. 150.00" required>
                    </div>
                    <div class="col-md-8 text-end mt-4">
                        <button type="button" id="adminSaveBtn" class="btn btn-primary btn-lg me-2">
                        <i class="fas fa-save"></i> Save Layout Changes
                    </button>


                        <button type="submit" class="btn btn-success btn-lg">Approve & Generate
                            Invoice</button>
                        <a href="/users" class="btn btn-secondary btn-lg">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
        <% } %>

            <button type="button" id="clearDesignBtn" class="btn btn-warning btn-lg">Clear
                Design</button>
            <!-- Form pointing to the design -->
            <form action="/users/<%= currentUser._id %>/design/save" method="POST" id="designForm">
                <!-- Hidden input to store the canvas JSON before sending to MongoDB -->
                <input type="hidden" name="canvasJSON" id="canvasJSONInput">

                <div class="container d-flex justify-content-between align-items-center my-3">
                    <h2 class="text-center">Design Area for <strong>
                            <%=user.username %>
                        </strong></h2>
                    <!-- Submit Button -->
                    <% if (currentUser.role==='user' ) { %>
                        <% // Robust check to see if the design is effectively empty 
                        
                        // 1. Parse the string into an object so we can read the arrays
   let designObj = { orders: [] };
   try {
       designObj = JSON.parse(user.designState || '{"orders": []}');
   } catch(e) { /* handle error */ }

   // 2. Check if the orders array is empty
   const isEmpty = (!designObj.orders || designObj.orders.length === 0);
                        
                        %>
                            <% if (currentUser.designStatus==='None' || currentUser.designStatus==='Rejected' ) { %>
                                <button type="submit" class="btn btn-success btn-lg" id="submitApprovalBtn" <%=isEmpty ? 'disabled' : ''
                                    %>>Submit for Approval</button>



                                <% } else { %>
                                    <div style="font-size: 1.5em;"> Current Design Status: <b>
                                            <%= currentUser.designStatus %>
                                        </b></div>
                                    <% } %>
                                        <% } %>



                </div>

                <div class="container text-center">
                    <div class="row">
                        <% for (let j=0; j<7; j++) {%>
                            <% if (j!==2) {%>
                                <div class="col">
                                    <!-- Changed to type="button" so it doesn't trigger form submission -->
                                    <button type="button" class="btn btn-primary designButton">
                                        <%=categories[j] %>
                                    </button>
                                    <select name="product" id="product-<%=j%>" placeholder="product"
                                        class="form-control" required>
                                        <% for(product of products) {%>
                                            <% if (product.category==categories[j]) {%>
                                                <option value="<%=product.name%>">
                                                    <%=product.brand %>
                                                        <%=product.name %> Stock:<%=product.quantity %>
                                                </option>
                                                <%} %>
                                                    <%} %>
                                    </select>
                                </div>
                                <%} %>
                                    <% } %>
                    </div>
                </div>

                <div class="container mt-3">
                    <div class="row">
                        <div class="col-4"></div>
                        <div class="col-4 cable-choice">
                            <b>Cable:</b>
                            <select name="product" id="cable-product" placeholder="product" class="form-control"
                                required>
                                <% for(product of products) {%>
                                    <% if (product.category==categories[2]) {%>
                                        <option value="<%=product.name%>">
                                            <%=product.brand %>
                                                <%=product.name %> Stock:<%=product.quantity %>
                                        </option>
                                        <%} %>
                                            <%} %>
                            </select>
                        </div>
                        <div class="col-4"></div>
                    </div>
                </div>
                <div class="row mt-4">
                    <div class="col-md-3">
                        <div
                            class="card shadow-sm border-<%= (currentUser.role === 'admin') ? 'primary' : 'secondary' %>">
                            <div
                                class="card-header <%= (currentUser.role === 'admin') ? 'bg-primary' : 'bg-secondary' %> text-white">
                                Design Summary & Stock
                            </div>
                            <ul class="list-group list-group-flush" id="stock-check-list">
                            </ul>
                        </div>
                    </div>

                    <div class="col-md-9 design-area" id="canvas-container"
                        style="position: relative; min-height: 500px; border: 1px solid #ddd;">
                        <svg id="cable-layer" class="cable-layer"
                            style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;"></svg>
                    </div>




                </div>


            </form>


            <div id="chat-container" class="shadow">
                <div id="chat-header" class="bg-primary text-white p-2 d-flex justify-content-between">
                    <span>Network Assistant</span>

                    <!-- request admin help -->
                    <button id="request-admin" class="btn btn-warning btn-sm">Admin Help</button>
                    <button id="close-chat" class="btn btn-sm text-white">▼</button>
                </div>

                <div class="chat-box">

                    <!-- Messages will appear here -->
                </div>
                <form id="send-chat">
    <div class="input-group">
        <input type="text" id="chat-input" class="form-control" placeholder="Ask about your design...">
        <button class="btn btn-primary" type="submit">Send</button>
    </div>
</form>
             
               <button id="clear-chat" class="btn btn-secondary btn-sm">🗑</button>
            </div>


            <script>
                // Use single quotes for the JSON string to avoid conflict with JSON double quotes
                window.SERVER_SAVED_DESIGN = '<%- (typeof savedDesign !== "undefined" && savedDesign) ? savedDesign : "{}" %>';
                window.CURRENT_USER_ID = "<%= currentUser._id %>";
                window.CURRENT_USER_USERNAME = "<%= currentUser.username %>"
            // The person who OWNS the design (the customer)
    window.TARGET_USER_ID = "<%= user._id %>";
            </script>