<% layout('layouts/boilerplateAdminPage') %>

    <style>
        /* Admin messages: Blue background, white text, aligned right */
        .msg-admin {
            background-color: #007bff;
            color: white;
            margin-left: auto;
        }

        /* User messages: White background, black text, aligned left */
        .msg-user {
            background-color: #ffffff;
            color: #212529;
            border: 1px solid #dee2e6;
        }

        /* Bot messages: Light gray background, aligned left */
        .msg-bot {
            background-color: #e9ecef;
            color: #495057;
            font-style: italic;
        }
    </style>

    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Chat with <%= conversation.userId.username %>
            </h2>
            <a href="/admin/conversations" class="btn btn-secondary btn-sm">Back to Inbox</a>
        </div>

        <div class="card shadow">
            <div id="admin-chat-box" class="card-body overflow-auto" style="height: 500px; background-color: #f8f9fa;">
                <% for(let msg of conversation.messages) { %>
                    <div
                        class="mb-3 d-flex <%= msg.sender === 'admin' ? 'justify-content-end' : 'justify-content-start' %>">
                        <div class="p-3 rounded shadow-sm msg-<%= msg.sender %>" style="max-width: 70%;">
                            <strong>
                                <%= msg.sender.toUpperCase() %>:
                            </strong><br>
                            <%= msg.text %>
                                <div class="text-end mt-1" style="font-size: 0.7rem; opacity: 0.8;">
                                    <%= msg.timestamp ? msg.timestamp.toLocaleTimeString() : '' %>
                                </div>
                        </div>
 <div class="message-item" data-timestamp="<%= msg.timestamp.toISOString() %>">
    </div>
                    </div>
                   
                    <% } %>
            </div>

            <div class="card-footer bg-white">
                <form id="admin-reply-form" class="input-group" data-user-id="<%= conversation.userId._id %>">
                    <input type="text" id="admin-msg-input" class="form-control" placeholder="Type your reply..."
                        required>
                    <button class="btn btn-primary" type="submit">Send Message</button>
                </form>
            </div>
            <div class="chat-controls mb-3">
                <button id="end-chat-btn" class="btn btn-success" data-user-id="<%= conversation.userId._id %>">
                    End Chat & Restore Bot
                </button>
                 <button id="clear-chat" class="btn btn-secondary btn-sm">Clear Chat🗑</button>
            </div>
        </div>
    </div>

    <script src="/js/admin-chat.js"></script>